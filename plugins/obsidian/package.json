{
  "name": "@csp/obsidian-plugin",
  "version": "0.1.16",
  "private": true,
  "description": "Context for Obsidian — sync your vault as agent-readable context via the Context Sync Protocol.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "build:wasm": "node ../../sdks/typescript/scripts/build-wasm.mjs",
    "build": "bun run build:wasm && node esbuild.config.mjs production",
    "dev": "bun run build:wasm && node esbuild.config.mjs",
    "install:vault": "bun run build && node scripts/install-vault.mjs",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test test/unit --coverage",
    "test:e2e": "bun test test/e2e --timeout=60000",
    "test:all": "bun run test && bun run test:e2e"
  },
  "dependencies": {
    "@csp/sdk": "file:../../sdks/typescript"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "@types/node": "^22.9.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.7.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=18"
  }
}
